# ════════════════════════════════════════════════════════════════
#  Exargen Command Center — Environment Variables
#  Copy this file to backend/.env and fill in your values.
#  NEVER commit backend/.env to git.
# ════════════════════════════════════════════════════════════════

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/exargen_cc

# ─── JWT Secrets ─────────────────────────────────────────────────────────────
# Must be at least 32 characters. Use different values for each secret.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_char_random_hex_string_access
JWT_REFRESH_SECRET=replace_with_64_char_random_hex_string_refresh
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Development: include both Vite ports (5173 default, 5174 if 5173 is taken).
# Production: set to your Vercel URL only — no localhost allowed.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# ─── CMS ─────────────────────────────────────────────────────────────────────
# Optional: explicit base URL for public CMS API responses (media URLs etc).
# Leave unset in development — the server auto-detects from the request.
# CMS_PUBLIC_BASE_URL=https://api.yourapp.com

# Optional: backend's own public URL — required in production so the
# Vite/Vercel frontend can pass Helmet's CSP connect-src check.
# BACKEND_PUBLIC_URL=https://api.yourapp.com

# ─── AI Provider — Content Engine ────────────────────────────────────────────
# The Content Engine uses an AI provider to analyse topics and generate blogs.
#
# SUPPORTED PROVIDERS
#   anthropic  →  Claude models (recommended)
#                 Get your key: https://console.anthropic.com → API Keys
#   openai     →  GPT-4o / any OpenAI-compatible API
#                 Get your key: https://platform.openai.com/api-keys
#
# RECOMMENDED MODELS
#   claude-haiku-4-5-20251001   Fast & cost-effective  (Anthropic default)
#   claude-sonnet-4-6           Balanced quality
#   claude-opus-4-7             Best quality
#   gpt-4o                      OpenAI default
#   gpt-4o-mini                 OpenAI fast & cheap
#
AI_PROVIDER=anthropic
AI_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the default model for the selected provider.
# AI_MODEL=claude-haiku-4-5-20251001

# Optional: only required for OpenAI-compatible custom endpoints
# (Azure OpenAI, local Ollama, etc). Leave unset for standard OpenAI/Anthropic.
# AI_BASE_URL=https://your-azure-openai-endpoint.openai.azure.com/v1

# ─── Infrastructure ──────────────────────────────────────────────────────────
# Number of reverse-proxy hops in front of this app (Railway/Render = 1).
# Increase to 2 if you add Cloudflare or a second proxy in front.
TRUSTED_PROXY_HOPS=1

# Set to true to log every Prisma SQL query to stdout (noisy — dev only).
PRISMA_LOG_QUERIES=false

# Set to true to seed demo data on first boot.
LOAD_SEED_DATA=false
