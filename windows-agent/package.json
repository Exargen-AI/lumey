{
  "name": "@exargen/pulse-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Headless Windows agent for the Exargen Command Center Pulse module. Runs as a Windows Service, collects device health + productivity telemetry, and POSTs to the backend via a per-device API key.",
  "main": "dist/index.js",
  "bin": {
    "pulse-agent": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "package": "pkg . --targets node20-win-x64 --output build/PulseAgent.exe",
    "build:installer": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File installer/build-installer.ps1",
    "install-service": "node dist/install-service.js",
    "uninstall-service": "node dist/install-service.js --uninstall"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "dotenv": "^16.4.5",
    "node-windows": "^1.0.0-beta.8"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "esbuild": "^0.24.0",
    "pkg": "^5.8.1",
    "postject": "^1.0.0-alpha.6",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "targets": [
      "node20-win-x64"
    ]
  }
}
