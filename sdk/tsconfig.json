{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    // CommonJS so the published client works via both `require` and `import`,
    // with classic (extensionless) module resolution for our relative imports.
    "module": "CommonJS",
    "moduleResolution": "node"
  },
  "include": ["src/**/*"],
  "exclude": ["**/*.test.ts"]
}
