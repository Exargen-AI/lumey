# Origin (no trailing slash, no /api/v1 — the axios client appends those).
#
# In dev: http://localhost:3000 (or whatever PORT your backend uses)
# On Vercel: set this in Project → Settings → Environment Variables to the
# Railway backend's public URL, e.g. https://<service>-production.up.railway.app
#
# QA finding H-C1: with no VITE_API_URL set on Vercel the SPA calls its own
# origin and every request 404s. This is a hard blocker for the first deploy.
VITE_API_URL=http://localhost:3000

# Inactivity-logout window in milliseconds. Default (when unset): 15 min.
# Set to `0` to DISABLE auto-logout entirely — useful in dev so debugging
# long flows doesn't constantly bounce you to /login (QA H-H6).
# Production should leave this unset.
# VITE_INACTIVITY_TIMEOUT_MS=0

# ── Error reporting (optional) ──────────────────────────────────────────
# Ingest URL for the frontend error reporter (src/lib/errorReporter.ts).
# When UNSET (the default), error reporting is a complete no-op — nothing
# is transmitted. When set to a collector endpoint (a Sentry DSN-style
# ingest URL or your own HTTPS collector), uncaught render errors,
# unhandled promise rejections, window.onerror, and 5xx/network API
# failures are POSTed as compact JSON (auth tokens + query strings are
# stripped first). If an @sentry/react SDK is loaded onto window.Sentry,
# the reporter delegates to it instead.
# VITE_ERROR_REPORTING_DSN=https://collector.example.com/ingest
#
# Optional release tag attached to each report for grouping (e.g. a git
# SHA or semver). Defaults to "unknown".
# VITE_APP_RELEASE=
