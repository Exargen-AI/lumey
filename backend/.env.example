# ── Database ──────────────────────────────────────────────────────────
# Append `?connection_limit=20` to the URL in production (Railway plan
# permitting). Bulk task ops run up to 8 concurrent transactions; with
# Prisma's default pool (~9–17 connections on typical hardware), leaving
# the default unset risks pool starvation on heavy batches (QA K-H1).
DATABASE_URL=postgresql://user:pass@host:5432/exargen_cc?schema=public

# ── JWT ───────────────────────────────────────────────────────────────
# Generate fresh values for each environment:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# `change-this-…` placeholders are REJECTED in production (see config/env.ts).
JWT_ACCESS_SECRET=change-this-to-a-random-64-character-string-for-access-tokens
JWT_REFRESH_SECRET=change-this-to-a-random-64-character-string-for-refresh-tokens
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Server ────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Comma-separated list of allowed Origin values for CORS + cookie credentials.
# In production, MUST be set explicitly to your frontend hostname(s) — the
# default localhost values are REJECTED at boot when NODE_ENV=production
# (QA finding H-H2). Vercel preview deploys land on `https://<project>-<hash>.vercel.app`;
# wildcards are supported (`https://*.vercel.app`) when you want to allow
# every preview, but most teams pin only the production URL + staging.
#
# Examples:
#   dev        → http://localhost:5173,http://localhost:5174
#   prod       → https://command-center.exargen.in
#   prod+stage → https://command-center.exargen.in,https://staging.command-center.exargen.in
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Public URL where THIS backend is reachable from the browser. Used by
# Helmet's CSP to whitelist connect-src so the SPA can fetch from us
# (QA finding H-C2). In dev the frontend talks to localhost so this is
# optional; in prod it's effectively required.
#   Railway → https://<service>-production.up.railway.app
# BACKEND_PUBLIC_URL=

# Number of reverse-proxy hops in front of the backend. Default 1
# matches Railway / Render / Heroku. Bump to 2 if you add Cloudflare
# or another CDN in front. Affects Express's `trust proxy` setting,
# which controls whether `req.ip` reads from `X-Forwarded-For` (used
# for IP-based rate limiting + audit context).
# TRUSTED_PROXY_HOPS=1

# ── CMS ───────────────────────────────────────────────────────────────
# Public-facing base URL for CMS asset / public-blog rendering. Used by
# `/cms/public/...` routes. Optional in dev; required wherever the CMS
# public site is consumed (QA finding H-H1 — was missing from this file).
# CMS_PUBLIC_BASE_URL=https://blog.exargen.in

# ── Logs ──────────────────────────────────────────────────────────────
PRISMA_LOG_QUERIES=false

# ── Seed ──────────────────────────────────────────────────────────────
# Set false in production. Seeded users carry the `Admin@1234` default
# password which is documented + therefore compromised; rotate via the
# admin reset script before any real user logs in.
LOAD_SEED_DATA=true

# ── Agent runtime: model providers (the 3-option router) ──────────────
# Lumey runs every agent through one OpenAI-compatible `ModelClient` seam,
# routed across three tiers (sovereign first: local → self-hosted →
# frontier). Configure any subset; an unconfigured tier just shows as a
# setup target on the Models page. An agent's policy model overrides the
# default; LUMEY_MODEL_BACKEND picks the default tier when set.
#
# 1) LOCAL — Ollama / llama.cpp on the box (air-gap, zero cost).
# LUMEY_LOCAL_MODEL=qwen2.5-coder:14b
# LUMEY_LOCAL_MODEL_URL=http://localhost:11434/v1   # default: Ollama
#
# 2) SELF_HOSTED — an OSS LLM on your server (vLLM / TGI), OpenAI-compatible.
# LUMEY_SELFHOSTED_MODEL=mixtral-8x7b-instruct
# LUMEY_SELFHOSTED_URL=https://gpu.internal:8000/v1
# LUMEY_SELFHOSTED_API_KEY=                          # optional bearer
#
# 3) FRONTIER — a hosted gateway (controlled, opt-in). API key required.
#    Any OpenAI-compatible model works here, e.g. GLM-4.6 via z.ai:
# LUMEY_FRONTIER_MODEL=glm-4.6
# LUMEY_FRONTIER_URL=https://api.z.ai/api/paas/v4
# LUMEY_FRONTIER_API_KEY=
#
# LUMEY_MODEL_BACKEND=local            # local | self-hosted | frontier (default tier)
# LUMEY_MODEL_TIMEOUT_MS=              # override the per-request deadline

# ── Agent runtime: governance + GitHub ────────────────────────────────
# Tools that require a human approval before they run (HITL approval gate).
# LUMEY_APPROVAL_TOOLS=open_pr         # comma-separated; empty disables the gate
# Sign run receipts with HMAC-SHA256 instead of a bare SHA-256 digest.
# LUMEY_RECEIPT_SECRET=
# GitHub (real PRs from agent runs): prefer a GitHub App over a PAT.
# LUMEY_GITHUB_TOKEN=                  # PAT fallback
# LUMEY_GITHUB_APP_ID=
# LUMEY_GITHUB_APP_PRIVATE_KEY=
# Run workspace + test command.
# LUMEY_RUN_REPO_PATH=                 # single-repo override (else per-project clone)
# LUMEY_TEST_CMD=npm test
