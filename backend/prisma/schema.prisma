// Captures the moment a user accepted the confidentiality terms for a specific
// project. One row per (user, project). Stores the snapshot of the agreed text
// + IP + UA so this is a legally-defensible audit record — survives even if the
// boilerplate text changes later.
model ProjectAcknowledgment {
  id               String   @id @default(uuid())
  userId           String
  projectId        String
  acknowledgedAt   DateTime @default(now())
  ipAddress        String?
  userAgent        String?  @db.Text
  acknowledgedText String   @db.Text

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId])
  @@map("project_acknowledgments")
}

// Agreed deliverables for a project — drives the client sign-off workflow.
// Status transitions: PENDING → IN_PROGRESS → DELIVERED → SIGNED_OFF (terminal)
//                                              ↘ REJECTED → IN_PROGRESS
model Deliverable {
  id                 String            @id @default(uuid())
  projectId          String
  title              String
  description        String?           @db.Text
  acceptanceCriteria String?           @db.Text
