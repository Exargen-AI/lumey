// CMS Enums
enum CmsBlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CmsTemplateType {
  ARTICLE
  TUTORIAL
  NEWS
  CASE_STUDY
  ANNOUNCEMENT
}

// CMS Content Project (represents external websites like Furix)
model CmsContentProject {
  id           String    @id @default(uuid())
  name         String
  slug         String    @unique
  description  String?   @db.Text
  apiKey       String    @unique
  // Optional list of scopes/permissions the API key grants to external
  // callers (e.g. ["leads.ingest"]). Empty = minimal public read access.
  apiKeyScopes String[]  @default([])
  domain       String?
  isActive     Boolean   @default(true)
  // Soft-delete (QA finding #33). Set to the deletion timestamp instead of
  // hard-deleting so we keep the audit chain (rotated API keys, blog history
  // for legal review) and can restore on accidental deletes. Public reads
  // and the admin list both filter `deletedAt: null`.
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  blogs                 CmsBlog[]
  mediaAssets           CmsMediaAsset[]
  templates             CmsTemplate[]
  contentEngineSearches ContentEngineSearch[]
  generatedBlogDrafts   GeneratedBlogDraft[]
  leads                 Lead[]

  @@index([deletedAt])
  @@map("cms_content_projects")
}

// External website lead submissions (ingested via public API keyed by
// CmsContentProject.apiKey). Stores a flat audit trail and status for
// follow-up. Duplicate detection is handled in the service layer.
enum LeadStatus {
  NEW
  CONTACTED
  CLOSED
}

model Lead {
