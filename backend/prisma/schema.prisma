  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  signedOffBy User?   @relation("DeliverableSignedOff", fields: [signedOffById], references: [id])

  @@index([projectId])
  @@map("deliverables")
}

model Comment {
  id          String    @id @default(uuid())
  projectId   String
  taskId      String?
  milestoneId String?
  authorId    String
  content     String    @db.Text
  isSeedData  Boolean   @default(false)
  // Comment subtype discriminator. "plain" = a normal thread comment
  // (the only kind before 2026-06). "story_update" = a structured
  // progress update an engineer posts against the task using the
  // client-facing story template; `storyData` then holds the parsed
  // fields and the FE renders it as a distinct card (not a plain
  // markdown bubble). Stored as a string (not a Prisma enum) so adding
  // future kinds stays an additive, migration-free change.
  kind        String    @default("plain")
  // Structured payload for a "story_update" comment — the parsed
  // template fields (objective, currentTask, reason, impact,
  // designChange, progress, nextStep). NULL for plain comments. The
  // `content` column always holds a plaintext rendering of the same
  // data so search, the productivity scorer, and any kind-unaware
  // reader still degrade gracefully.
  storyData   Json?
  // Set on the first edit (author's own PATCH /comments/:id). Lets the FE
  // render an "edited" badge without confusing it with the auto-bumping
  // `updatedAt` (which moves on any field, including future system-driven
  // updates). Round 2 follow-up R2.
  editedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task      Task?      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  milestone Milestone? @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  author    User       @relation(fields: [authorId], references: [id])

  @@index([projectId])
  @@index([taskId])
  // The client task view pins the latest story update — query is
  // "comments on this task of kind story_update, newest first".
  @@index([taskId, kind])
  @@map("comments")
}

model StatusUpdate {
  id        String       @id @default(uuid())
  projectId String
  authorId  String
  signal    HealthStatus
  note      String?      @db.Text
  createdAt DateTime     @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id])

  @@index([projectId])
  @@map("status_updates")
}

model Activity {
  id         String   @id @default(uuid())
  projectId  String?
  userId     String
  action     String
  targetType String?
  targetId   String?
  details    Json?
  createdAt  DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id])

  @@index([projectId])
  @@index([userId])
  @@index([createdAt])
  @@map("activities")
}

// ─── IDEMPOTENCY ─────────────────────────────────────────────────────────
//
// 2026-05-23 — Layer 2 (agent control) infrastructure.
//
// Agents (and any other API client) can send an `Idempotency-Key` header on
// state-changing requests so that a retry after a network failure replays
// the original response instead of creating a duplicate resource. Without
// this, an agent that times out on POST /tasks doesn't know whether the
// task was created — and naively retrying would create two tasks.
//
// Contract (matches Stripe's well-known shape so external developers
// recognize it immediately):
//
//   • Client sends `Idempotency-Key: <opaque-string>` on POST/PATCH/PUT/DELETE.
//   • Server fingerprints the request body + path + method into `requestHash`.
//   • If (userId, key, method, path) exists AND requestHash matches:
//       → REPLAY the stored response (same status + body).
//   • If exists AND requestHash differs:
//       → 422 "Idempotency-Key reused with a different request body"
//   • If absent:
//       → Process normally. AFTER the handler responds, store the response.
//
// TTL: 24 hours. The platform doesn't need longer because (a) any well-
// behaved client retries within seconds, not days, and (b) the storage
// grows linearly with traffic without periodic cleanup. A scheduled
// `deleteMany({ where: { expiresAt: { lt: now } } })` runs daily.
//
// Scoping: per-user. Two different agents using the same key string get
// independent dedupes — keys aren't a global namespace.
model IdempotencyKey {
  id String @id @default(uuid())

  // The composite uniqueness contract — these three together identify a
  // "same request" attempt. Path is stored as the original :param-templated
  // path (not the resolved URL), so the same logical mutation on different
  // resources doesn't collide.
  key    String
  userId String
  method String // HTTP verb, uppercase
  path   String // /api/v1/projects/:id/tasks (templated)

  // SHA-256 of (method + path + sorted body JSON). When a retry comes in,
  // we compare this. Mismatched bodies under the same key are explicit
  // misuse and get a 422.
  requestHash String

  // The stored response we'll replay. statusCode is the HTTP status that
  // was sent; responseBody is the JSON the server returned. Both are
  // captured by the middleware AFTER the handler resolves.
  statusCode   Int
  responseBody Json

  createdAt DateTime @default(now())
  expiresAt DateTime // createdAt + 24h, indexed for cleanup sweep

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key, method, path])
  @@index([userId])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

// ─── TIMESHEETS ───

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

model TimesheetWeek {
  id              String          @id @default(uuid())
