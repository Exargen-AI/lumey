// ─── CONTENT ENGINE ──────────────────────────────────────────────────────────
//
// The Content Engine is an AI-powered trend discovery + blog generation tool
// embedded inside the CMS. Operators search a topic; the backend calls the
// configured AI provider (Anthropic Claude by default) which synthesises
// current online discussions, sentiment, SEO keywords, and blog ideas from
// its training data. Operators then generate full blog drafts and push them
// directly into the existing CmsBlog draft workflow.
//
// Three tables:
//   ContentEngineSearch  — one row per operator search (topic + filters)
//   AiAnalysisResult     — structured AI output for a search
//   GeneratedBlogDraft   — AI-generated blog content before CMS promotion
//

model ContentEngineSearch {
  id              String   @id @default(uuid())
  projectId       String
  createdById     String
  topic           String
  timeRange       String? // '24h' | '7d' | '30d' — operator-selected filter
  sentimentFilter String? // 'positive' | 'negative' | 'neutral' — operator-selected filter
  createdAt       DateTime @default(now())

  project   CmsContentProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User               @relation("ContentEngineSearchCreator", fields: [createdById], references: [id])
  results   AiAnalysisResult[]

  @@index([projectId])
  @@index([createdById])
  @@map("content_engine_searches")
}

model AiAnalysisResult {
  id                String   @id @default(uuid())
  searchId          String
  topic             String
  summary           String   @db.Text
  sentiment         Json // { label: string, confidence: number }
  trendScore        Int
  viralScore        Int
  engagementInsight String   @db.Text
  trendingSubtopics String[]
  commonQuestions   String[]
  painPoints        String[]
  seoKeywords       Json // { primary: string[], long_tail: string[], questions: string[] }
  blogIdeas         Json // Array<{ title: string, angle: string, target_audience: string }>
  recommendedTitle  String
  recommendedTags   String[]
  rawResponse       Json // Full AI provider response (for audit / replay)
  createdAt         DateTime @default(now())

  search          ContentEngineSearch  @relation(fields: [searchId], references: [id], onDelete: Cascade)
  generatedDrafts GeneratedBlogDraft[]

  @@index([searchId])
  @@map("ai_analysis_results")
}

model GeneratedBlogDraft {
  id          String   @id @default(uuid())
  analysisId  String
  projectId   String
  createdById String
  cmsBlogId   String? // Set once the draft is promoted to a real CmsBlog entry
  title       String
  slug        String
  excerpt     String   @db.Text
  content     Json // Block-based content matching CmsBlog.content structure
  seo         Json? // { title, description, keywords }
  tags        String[]
  categories  String[]
  // 'generated' = AI-produced, not yet in CMS
  // 'draft_created' = promoted to a CmsBlog DRAFT
  status      String   @default("generated")
  createdAt   DateTime @default(now())

  analysis  AiAnalysisResult  @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  project   CmsContentProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User              @relation("GeneratedBlogDraftCreator", fields: [createdById], references: [id])

  @@index([analysisId])
  @@index([projectId])
  @@map("generated_blog_drafts")
