  id           String   @id @default(uuid())
  projectId    String
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String
  altText      String?  @db.Text
  caption      String?  @db.Text
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project CmsContentProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("cms_media_assets")
}

// ─── Compliance / Onboarding course models ───
//
// A `Course` is an authored compliance training (NDA + IP + No-Moonlighting + …).
// Each course has multiple `CourseModule`s (content + optional Quiz) and multiple
// `CourseDocument`s (the legally-binding texts). A user is `Enrollment`-ed in a
// course; they progress through modules, take quizzes, and finish by signing each
// document — producing one `DocumentSignature` row per (user, document, version).
// Bumping `Course.version` triggers re-enrollment so consent stays current.

model Course {
  id                         String       @id @default(uuid())
  slug                       String       @unique
  title                      String
  description                String?      @db.Text
  version                    Int          @default(1)
  isMandatoryOnHire          Boolean      @default(false)
  passingScore               Int          @default(80)
  // Per-user acknowledgment validity in days. Null = never expires (one-time
  // acknowledgment). 365 = annual re-acknowledgment. Used by the maintenance
  // job to compute Enrollment.expiresAt at completion time.
  acknowledgmentValidityDays Int?
  applicableRoles            UserRole[]
  status                     CourseStatus @default(DRAFT)
  publishedAt                DateTime?
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt

  modules     CourseModule[]
  documents   CourseDocument[]
  enrollments Enrollment[]

  @@index([status, isMandatoryOnHire])
  @@map("courses")
}

model CourseModule {
  id               String   @id @default(uuid())
  courseId         String
  order            Int
  title            String
  contentBlocks    Json     @default("[]")
  estimatedMinutes Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  course   Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  quiz     Quiz?
  progress ModuleProgress[]

  @@unique([courseId, order])
  @@index([courseId])
  @@map("course_modules")
}

model CourseDocument {
  id        String   @id @default(uuid())
  courseId  String
  slug      String
  title     String
  bodyText  String   @db.Text
  version   Int      @default(1)
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course     Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  signatures DocumentSignature[]

  @@unique([courseId, slug])
  @@index([courseId])
  @@map("course_documents")
}

model Quiz {
  id           String   @id @default(uuid())
  moduleId     String   @unique
  passingScore Int      @default(80)
  allowRetry   Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  module    CourseModule   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@map("quizzes")
}

model QuizQuestion {
  id          String       @id @default(uuid())
  quizId      String
  order       Int
  prompt      String       @db.Text
  type        QuestionType @default(MULTIPLE_CHOICE)
  options     Json         @default("[]")
  explanation String?      @db.Text

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([quizId, order])
  @@map("quiz_questions")
}

model Enrollment {
  id            String    @id @default(uuid())
  userId        String
  courseId      String
  courseVersion Int
  // Acknowledgment cycle. Starts at 1. Bumped each time the user re-takes the
  // course (annual expiry, manual force-expire). Combined with courseVersion
  // makes uniqueness work for multiple acknowledgments at the same version.
  cycle         Int       @default(1)
  enrolledAt    DateTime  @default(now())
  completedAt   DateTime?
  declinedAt    DateTime?
  // Computed at completion as completedAt + Course.acknowledgmentValidityDays.
  // Null means either not yet completed, or course has no expiry.
  expiresAt     DateTime?

  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  course         Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  moduleProgress ModuleProgress[]
  quizAttempts   QuizAttempt[]
  signatures     DocumentSignature[]

  @@unique([userId, courseId, courseVersion, cycle])
  @@index([userId])
  @@index([courseId])
  @@index([expiresAt])
  @@map("enrollments")
}

model ModuleProgress {
  id               String    @id @default(uuid())
  enrollmentId     String
  moduleId         String
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  scrolledToBottom Boolean   @default(false)
  timeOnPageSec    Int       @default(0)
  quizPassed       Boolean   @default(false)

  enrollment Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  module     CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, moduleId])
  @@map("module_progress")
}

model QuizAttempt {
  id            String    @id @default(uuid())
  enrollmentId  String
  quizId        String
  attemptNumber Int
  startedAt     DateTime  @default(now())
  submittedAt   DateTime?
  scorePercent  Int?
  passed        Boolean   @default(false)
  answers       Json      @default("[]")

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  quiz       Quiz       @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([enrollmentId])
  @@map("quiz_attempts")
}

// Legally-defensible signature record. One row per (enrollment, document, version).
// signedTextSnapshot holds the FULL agreement text at sign time so future edits to
// CourseDocument.bodyText cannot retroactively alter what the user agreed to.
model DocumentSignature {
  id                 String   @id @default(uuid())
  enrollmentId       String
  courseDocumentId   String
  documentVersion    Int
  signedAt           DateTime @default(now())
  signedName         String
  signedTextSnapshot String   @db.Text
  ipAddress          String?
  userAgent          String?  @db.Text
  passwordReentered  Boolean  @default(false)
  externalProvider   String?
  externalEnvelopeId String?
  externalAuditUrl   String?

  enrollment     Enrollment     @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  courseDocument CourseDocument @relation(fields: [courseDocumentId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, courseDocumentId, documentVersion])
  @@index([enrollmentId])
  @@map("document_signatures")
}

// Per-user notification mute preferences.
//
// Design:
//   - One row per (userId, type) — sparse storage. The DEFAULT is
//     "not muted"; absence of a row means the user wants the
//     notification. Only opt-OUT entries persist.
//   - `type` is a free-form string matching the values used in
//     notification.service.ts (e.g. 'task_nudge'). NOT a Prisma enum
//     because we add new notification types in nearly every feature
//     PR — a schema migration per new type would be silly. The
//     authoritative list lives in src/constants/notificationTypes.ts
//     and is validated at the validator boundary.
//   - Cascade on user delete: when an account is removed, drop their
//     preferences with them. Don't leak settings to a future user
//     who happens to take the same id (UUIDs make collision
//     impossible in practice, but the cascade is the right safety).
model NotificationPreference {
  id        String   @id @default(uuid())
  userId    String
  type      String
  muted     Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
  @@map("notification_preferences")
}

// ─── DEVELOPMENTOPS MODULE ───

enum GitProvider {
  GITHUB
  GITLAB
  BITBUCKET
}

enum RepositoryActivityType {
  COMMIT
  PR_OPENED
  PR_MERGED
  BRANCH_CREATED
  RELEASE_PUBLISHED
}

enum EnvironmentType {
  DEVELOPMENT
  STAGING
  PRODUCTION
}

enum EnvironmentStatus {
  HEALTHY
  DEGRADED
  DOWN
  UNKNOWN
}

enum PipelineStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

enum DeploymentStatus {
  PENDING
  IN_PROGRESS
  SUCCESS
  FAILED
  ROLLED_BACK
}

// Repository connection for Git providers
model Repository {
  id            String      @id @default(uuid())
  projectId     String
  provider      GitProvider
  repoName      String
  repoOwner     String
  repoUrl       String
  accessToken   String? // Encrypted at rest via DB encryption
  defaultBranch String      @default("main")
  isPrivate     Boolean     @default(false)
  createdBy     String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  project     Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator     User                 @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  activities  RepositoryActivity[]
  pipelines   Pipeline[]
  deployments Deployment[]
  releases    Release[]

  @@unique([projectId, provider, repoOwner, repoName])
  @@index([projectId])
  @@map("repositories")
}

// Track Git activities (commits, PRs, releases, etc.)
model RepositoryActivity {
  id           String                 @id @default(uuid())
  projectId    String
  repositoryId String
  activityType RepositoryActivityType
  externalId   String // Prevent duplicates: provider + externalId
  title        String
  description  String?
  authorName   String?
  branchName   String?
  activityUrl  String?
  metadataJson Json                   @default("{}")
  createdAt    DateTime               @default(now())

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  repository  Repository   @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  linkedTasks LinkedTask[]

  @@unique([repositoryId, externalId])
  @@index([projectId])
  @@index([repositoryId, createdAt(sort: Desc)])
  @@map("repository_activities")
}

// Link activities to tasks for cross-module visibility
model LinkedTask {
  id                   String   @id @default(uuid())
  repositoryActivityId String
  taskId               String
  createdAt            DateTime @default(now())

  activity RepositoryActivity @relation(fields: [repositoryActivityId], references: [id], onDelete: Cascade)
  task     Task               @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([repositoryActivityId, taskId])
  @@index([taskId])
  @@map("linked_tasks")
}

// Environment management (dev, staging, prod)
model Environment {
  id            String            @id @default(uuid())
  projectId     String
  name          String
  type          EnvironmentType
  branchName    String?
  deploymentUrl String?
  status        EnvironmentStatus @default(UNKNOWN)
  description   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deployments Deployment[]

  @@unique([projectId, name])
  @@index([projectId])
  @@map("environments")
}

// CI/CD Pipelines
model Pipeline {
  id                 String      @id @default(uuid())
  repositoryId       String
  provider           GitProvider
  pipelineName       String
  externalPipelineId String
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  repository Repository    @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  runs       PipelineRun[]

  @@unique([repositoryId, externalPipelineId])
  @@index([repositoryId])
  @@map("pipelines")
}

// Pipeline execution history
model PipelineRun {
  id          String         @id @default(uuid())
  pipelineId  String
  runNumber   Int
  status      PipelineStatus
  conclusion  String?
  branch      String?
  triggeredBy String?
  startedAt   DateTime?
  completedAt DateTime?
  externalUrl String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@unique([pipelineId, runNumber])
  @@index([pipelineId, status])
  @@index([pipelineId, completedAt(sort: Desc)])
  @@map("pipeline_runs")
}

// Deployment tracking
model Deployment {
  id               String           @id @default(uuid())
  projectId        String
  environmentId    String
  repositoryId     String
  version          String
  deployedBy       String?
  deploymentStatus DeploymentStatus @default(PENDING)
  deploymentTime   DateTime?
  commitSha        String?
  releaseNotes     String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  project        Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment    Environment @relation(fields: [environmentId], references: [id], onDelete: Restrict)
  repository     Repository  @relation(fields: [repositoryId], references: [id], onDelete: Restrict)
  deploymentUser User?       @relation(fields: [deployedBy], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([environmentId, createdAt(sort: Desc)])
  @@index([repositoryId])
  @@map("deployments")
}

// Release tracking
model Release {
  id           String    @id @default(uuid())
  repositoryId String
  releaseTag   String
  releaseName  String?
  releaseNotes String?
  publishedAt  DateTime?
  createdBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  creator    User?      @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([repositoryId, releaseTag])
  @@index([repositoryId, publishedAt(sort: Desc)])
  @@map("releases")
}

// Add relationships to existing models
// Project relations added above: repositories, deployments, environments
// User relations: createdRepositories, deploymentsCreated, releasesCreated
// ─── PULSE — Device Health + Employee Productivity (2026-05-28) ───
//
// Telemetry surface for the headless Windows agent (Command Center desktop
// companion). SUPER_ADMIN-only — the agent posts heartbeats + periodic
// full snapshots; all reads are gated behind requireRoles('SUPER_ADMIN')
// at the route layer plus an additional service-layer check.
//
// CRITICAL invariant: the agent NEVER writes the DB directly. All traffic
// flows through backend services that authenticate the agent via a
// per-device API key (Authorization: Device <token>). The auth middleware
// validates the key against Device.apiKeyHash (sha-256, constant-time
// compare) and refuses inactive/revoked devices before any handler runs.
//
// Enrollment flow:
//   1. SUPER_ADMIN issues a single-use DeviceEnrollmentToken for an
//      employee (optionally pre-bound to that user).
//   2. Employee runs the installer; agent reads the token from its
//      install-time config.
//   3. Agent POSTs /api/v1/devices/enroll with the token + hardware
//      fingerprint (machine UUID + primary MAC + OS install id).
//   4. Backend creates a Device row, generates a fresh API key, hashes
//      it, returns the cleartext ONCE in the response, and marks the
//      enrollment token CONSUMED.
//   5. All future heartbeats/snapshots use the API key.
//
// Telemetry rhythm:
//   - Heartbeat (~5 min): touches Device.lastSeenAt + currentPowerState
//     only. Cheap, frequent. No history row written.
//   - Full snapshot (~60 min): writes a DeviceHealthSnapshot row, upserts
//     the installed-software + missing-patch tables, runs the risk
//     scorer, opens/resolves risk alerts.

enum DevicePlatform {
  WINDOWS
  MACOS
  LINUX
}

enum DeviceEnrollmentStatus {
  PENDING_ENROLLMENT
  ACTIVE
  REVOKED
  INACTIVE
}

enum DevicePowerState {
  ON
  IDLE
  LOCKED
  OFF
}

enum DeviceRiskLevel {
  HEALTHY
  AT_RISK
  CRITICAL
}

enum DeviceAlertType {
  AGENT_OFFLINE
  MISSING_CRITICAL_PATCHES
  REBOOT_REQUIRED_OVERDUE
  ANTIVIRUS_DISABLED
  FIREWALL_DISABLED
  BITLOCKER_DISABLED
  UNSUPPORTED_OS
  RISKY_SOFTWARE_INSTALLED
  HIGH_RISK_SCORE
  // 2026-05-29 — Anti-tamper. Fires when the agent goes quiet for an
  // unexpectedly long window during what should be active hours.
  HEARTBEAT_GAP_DETECTED
  // 2026-05-29 — Anti-tamper. Fires when a mouse-jiggler / Caffeine-
  // style "keep awake" process is detected in the foreground or as a
  // long-running process.
  TAMPER_TOOL_DETECTED
  // 2026-05-29 — Fires when an entertainment app dominates the
  // foreground for an unusual portion of the workday.
  EXCESSIVE_DISTRACTION
}

enum DeviceAlertSeverity {
  INFO
  WARNING
  CRITICAL
}

model Device {
  id String @id @default(uuid())

  // Stable hardware fingerprint (machine UUID + primary MAC + OS install
  // id, hashed). Re-enrolling the same machine produces the same value,
  // which lets us detect "agent reinstalled on the same laptop" vs.
  // "fresh device".
  fingerprint String @unique

  hostname  String
  platform  DevicePlatform
  osVersion String?
  osBuild   String?
  arch      String?

  // Owning employee. Nullable: a device may be enrolled before owner
  // assignment, or it may be a shared kiosk. SET NULL on user delete
  // preserves the telemetry record for reassignment.
  ownerUserId String?
  owner       User?   @relation("DeviceOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  // Per-device API key — only the hash is stored. Cleartext is shown
  // once at enrollment and never retrievable. Rotation goes through a
  // SUPER_ADMIN-only endpoint that revokes + reissues.
  apiKeyHash   String @unique
  // First 8 chars of the cleartext key for log search / audit display.
  // Not a secret — same shape as Stripe's `sk_live_...` prefix surface.
  apiKeyPrefix String

  status          DeviceEnrollmentStatus @default(ACTIVE)
  revokedAt       DateTime?
  revokedByUserId String?
  revokedBy       User?                  @relation("DeviceRevoker", fields: [revokedByUserId], references: [id], onDelete: SetNull)
  revokedReason   String?

  agentVersion    String?
  lastSeenAt      DateTime?
  // Audit-only; never used for auth or rate limiting decisions here.
  lastHeartbeatIp String?

  // ─── Wave 9 — agent self-health (2026-05-30) ───────────────────
  // Captured on every heartbeat so the admin can spot an agent that's
  // bleeding memory, throwing errors silently, or running on a CPU-
  // starved machine. Nullable for back-compat with pre-Wave-9 agents.
  lastCpuPercent        Float?
  lastMemoryMb          Float?
  agentErrorCount       Int       @default(0)
  agentLastErrorAt      DateTime?
  agentLastErrorMessage String?

  // Denormalized current rollup so the admin list view doesn't have to
  // join the latest snapshot for every row. Recomputed on each snapshot.
  currentRiskScore  Int?
  currentRiskLevel  DeviceRiskLevel?
  currentPowerState DevicePowerState?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollmentToken   DeviceEnrollmentToken?    @relation("EnrollmentTokenDevice")
  snapshots         DeviceHealthSnapshot[]
  installedSoftware DeviceInstalledSoftware[]
  missingPatches    DeviceMissingPatch[]
  riskAlerts        DeviceRiskAlert[]
  appActivity       DeviceAppActivity[]

  @@index([ownerUserId])
  @@index([status])
  @@index([currentRiskLevel])
  @@index([lastSeenAt])
  @@map("devices")
}

model DeviceEnrollmentToken {
  id String @id @default(uuid())

  // SHA-256 hash of the single-use bootstrap token. The cleartext is
  // returned exactly once at issuance and is NEVER stored — an attacker
  // with DB read access (leaked backup, errant SQL, insider) cannot
  // recover a usable token. On enrollment the agent presents the
  // cleartext; we hash it and look up by this column. Same at-rest
  // posture as Device.apiKeyHash. (2026-06-01 enterprise-hardening M7.)
  tokenHash String @unique

  // Last 4 chars of the cleartext token, kept solely for the admin list
  // view's masked display ("····ab12"). 4 hex chars carry no brute-force
  // value, so this is safe to store in the clear.
  tokenLast4 String

  // Optional pre-binding. When set, the device is auto-assigned to this
  // user on enrollment.
  assignedUserId String?
  assignedUser   User?   @relation("EnrollmentTokenAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)

  issuedByUserId String
  issuedBy       User   @relation("EnrollmentTokenIssuer", fields: [issuedByUserId], references: [id])

  expiresAt          DateTime
  consumedAt         DateTime?
  consumedByDeviceId String?   @unique
  consumedByDevice   Device?   @relation("EnrollmentTokenDevice", fields: [consumedByDeviceId], references: [id], onDelete: SetNull)

  // SUPER_ADMIN-visible memo: e.g. "Pankaj's new laptop", "shared QA box".
  note String?

  createdAt DateTime @default(now())

  @@index([assignedUserId])
  @@index([issuedByUserId])
  @@index([expiresAt])
  @@map("device_enrollment_tokens")
}

model DeviceHealthSnapshot {
  id       String @id @default(uuid())
  deviceId String
  device   Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  capturedAt DateTime @default(now())

  // Productivity / presence (agent-computed; backend does NOT trust
  // these for billing — just for the SUPER_ADMIN view).
  powerState          DevicePowerState
  uptimeSeconds       Int              @default(0)
  lastBootAt          DateTime?
  // 2026-05-29 — When the current interactive Windows session started.
  // Comes from Win32_LogonSession.StartTime. Distinct from lastBootAt
  // (the machine has been up since the boot; the user may have logged
  // in much later).
  currentSessionStart DateTime?
  // 2026-05-29 — Total process count from Get-Process. Cheap sanity
  // signal — a normal Windows session has 100–300 processes; numbers
  // way off may indicate tampering or a hung agent.
  runningProcessCount Int?
  // Windows account name of the logged-in user at capture time. Used
  // ONLY for cross-checking against the registered device owner; we
  // surface a soft warning if they diverge ("device owner is X, but Y
  // is signed in").
  loggedInUserName    String?

  // Security posture. Windows-first; other platforms may leave these
  // null where the concept doesn't apply.
  defenderEnabled    Boolean?
  firewallEnabled    Boolean?
  bitlockerEnabled   Boolean?
  rebootRequired     Boolean?
  pendingRebootSince DateTime?
  unsupportedOs      Boolean?

  // Risk rollup frozen at this snapshot so we can plot history without
  // re-running the scorer. The CURRENT score on Device is the latest
  // value; here we keep the trail.
  riskScore Int
  riskLevel DeviceRiskLevel

  // Denormalized counts for cheap trend queries.
  missingPatchCount  Int @default(0)
  criticalPatchCount Int @default(0)
  riskySoftwareCount Int @default(0)

  // 2026-05-28b — Productivity rollup. The Windows agent tracks the
  // time spent in each powerState since the LAST snapshot and reports
  // it here. We sum across snapshots to draw the "today's active /
  // locked / idle" view on the admin dashboard. activeSecondsBucket +
  // lockedSecondsBucket + idleSecondsBucket roughly equal the snapshot
  // interval; remainder is treated as OFF (agent wasn't running).
  activeSecondsBucket Int @default(0)
  idleSecondsBucket   Int @default(0)
  lockedSecondsBucket Int @default(0)

  // ─── Wave 9 — agent resilience signals (2026-05-30) ─────────────
  // Battery: laptops only. Desktops without batteries leave these null.
  batteryPercent         Int?
  batteryCharging        Boolean?
  batteryHealthPercent   Int?
  // Disk: free percent + bytes on the OS volume.
  diskFreePercent        Int?
  diskFreeGb             Float?
  // Network: which connection is the agent on right now?
  networkType            String? // ETHERNET / WIFI / CELLULAR / VPN / UNKNOWN
  networkConnectivity    String? // INTERNET / LOCAL_ONLY / NO_TRAFFIC / UNKNOWN
  // Background-process tamper detection. Distinct from the foreground
  // TAMPER bucket — these processes ran without ever holding focus,
  // which is the prime mode of a real mouse-jiggler. JSON array of
  // `{name, pid}` objects.
  runningTamperProcesses Json?
  // Snapshot-level tamper rollup so the admin list view doesn't have
  // to count JSON every read.
  tamperProcessCount     Int      @default(0)

  agentVersion String?

  @@index([deviceId, capturedAt])
  @@index([capturedAt])
  @@index([riskLevel])
  @@map("device_health_snapshots")
}

model DeviceInstalledSoftware {
  id       String @id @default(uuid())
  deviceId String
  device   Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  name        String
  version     String?
  publisher   String?
  installDate DateTime?

  // Backend-set classification. Examples: known credential stealers,
  // remote-access tools, crypto miners, anything on the SUPER_ADMIN-
  // maintained block list. The classifier runs at ingestion time; a
  // future SUPER_ADMIN UI will let block-list rules be edited and
  // back-applied.
  isRisky    Boolean @default(false)
  riskReason String?

  // Upsert keeps firstSeenAt stable across refreshes; lastSeenAt bumps
  // every full snapshot. Apps no longer present after a refresh are
  // pruned by the ingestion step.
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  @@unique([deviceId, name, version])
  @@index([deviceId])
  @@index([isRisky])
  @@map("device_installed_software")
}

model DeviceMissingPatch {
  id       String @id @default(uuid())
  deviceId String
  device   Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  // KB id (e.g., "KB5032190") for Windows; vendor-specific id otherwise.
  patchId        String
  title          String?
  classification String? // "Security Updates", "Critical Updates", ...
  severity       String? // "Critical", "Important", "Moderate", "Low"
  releasedAt     DateTime?

  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  @@unique([deviceId, patchId])
  @@index([deviceId])
  @@index([severity])
  @@map("device_missing_patches")
}

model DeviceRiskAlert {
  id       String @id @default(uuid())
  deviceId String
  device   Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  type     DeviceAlertType
  severity DeviceAlertSeverity
  message  String

  // Open / resolved lifecycle. Alerts are auto-opened by the risk-scoring
  // step on snapshot ingest and auto-resolved on the next snapshot that
  // no longer matches the trigger (e.g., reboot completed, AV re-enabled).
  // SUPER_ADMINs can also manually resolve with a note. The service layer
  // enforces "at most one OPEN alert per (deviceId, type)" — duplicates
  // collapse to an updated existing row.
  openedAt         DateTime  @default(now())
  resolvedAt       DateTime?
  resolvedByUserId String?
  resolvedBy       User?     @relation("AlertResolver", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  resolutionNote   String?

  @@index([deviceId])
  @@index([type])
  @@index([severity])
  @@index([resolvedAt])
  @@index([deviceId, type, resolvedAt])
  @@map("device_risk_alerts")
}

// ─── PULSE — App activity (2026-05-29) ───
//
// Per-device foreground app activity in hourly buckets. The agent
// samples the foreground window every 30 seconds, accumulates seconds
// per app, and ships the bucket on each hourly snapshot.
//
// Why one row per (device, bucket-window, app) rather than a row per
// 30-sec sample: 30-sec resolution → 2,880 rows / day / device. With
// 100 devices that's 288K rows / day. Hourly buckets reduce this by
// ~50x while preserving "how much time on each app per hour" — more
// than enough for the per-employee productivity view.
//
// Window titles are kept (latest seen during the bucket) so the
// SUPER_ADMIN can see what was being worked on. Cross-checked against
// the YouTube/Netflix/etc. pattern list at ingestion time and tagged
// with a category for fast filtering.

enum AppCategory {
  // The signal "this employee is heads-down":
  PRODUCTIVE // Code editors, Office, design tools, terminals
  COMMUNICATION // Slack, Teams, Zoom, work email
  // The signals to watch:
  ENTERTAINMENT // YouTube, Netflix, Steam, Twitch, gaming
  PERSONAL // Social media, personal browsing
  // Catch-all:
  UNKNOWN // Anything not matched by the built-in classifier
  // Anti-cheat:
  TAMPER // Mouse jigglers, Caffeine-style keep-awake tools
}

model DeviceAppActivity {
  id       String @id @default(uuid())
  deviceId String
  device   Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  // The bucket window (typically 1 hour starting from a UTC hour boundary).
  bucketStart DateTime
  bucketEnd   DateTime

  // Process executable name (e.g. "chrome.exe", "Code.exe"). Stored
  // lower-case for case-insensitive matching against the classifier.
  appName         String
  // Friendly name if known (e.g. "Google Chrome", "Visual Studio Code").
  appDisplayName  String?
  // The window title last seen for this app in this bucket. Used for
  // browser distraction detection (e.g. title contains "YouTube").
  // Truncated to 512 chars to bound storage.
  lastWindowTitle String?

  // Classification at ingestion time.
  category       AppCategory @default(UNKNOWN)
  // If the category is ENTERTAINMENT/PERSONAL/TAMPER, the reason —
  // surfaces in admin UI explanations ("Matched: YouTube via window title").
  categoryReason String?

  // Time spent with this app in the foreground during the bucket.
  foregroundSeconds Int @default(0)

  // When this row was inserted (debugging / late arrival detection).
  capturedAt DateTime @default(now())

  // The de-dup key: a retry of the same bucket merges rather than
  // duplicating. Service layer enforces upsert on this key.
  @@unique([deviceId, bucketStart, appName])
  @@index([deviceId, bucketStart])
  @@index([category])
  @@index([capturedAt])
  @@map("device_app_activity")
}

// ─── PULSE — Clock In / Clock Out (2026-05-28b) ───
//
// Employee-self clock-in/out. Distinct from automatic powerState
// telemetry (the device may be on while the employee isn't working,
// or the employee may be working without their laptop). This is the
// human's declared work session.
//
// One row per session. clockedOutAt is null while the session is
// open; the service layer refuses a second clockIn while one is
// open. Sessions still open after 12h are auto-closed with
// autoClosedAt set so the SUPER_ADMIN view can flag forgot-to-clock-
// out cases without polluting the user's clock history.
//
// Privacy: an employee sees only their own sessions. SUPER_ADMIN sees
// the team view via the Pulse admin endpoint.

model ClockSession {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation("ClockSessionUser", fields: [userId], references: [id], onDelete: Cascade)
  clockedInAt  DateTime  @default(now())
  clockedOutAt DateTime?
  // Set when the auto-close sweep fires (>12h still open) so the row
  // is distinguishable from a user-initiated clock-out. resolvedOutAt
  // == COALESCE(clockedOutAt, autoClosedAt) for display.
  autoClosedAt DateTime?
  // Free-text per session — what the user is working on. Optional.
  noteIn       String?
  noteOut      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, clockedInAt])
  // Open-session lookup hot path (where userId = X and clockedOutAt is
  // null) used on every clock-in to refuse double-clocks.
  @@index([userId, clockedOutAt])
  @@map("clock_sessions")
}

// ────────────────────────────────────────────────────────────────────
// Composite Productivity Score (2026-05-29, R5)
//
// Multi-signal monthly productivity score. Universal weights — no
// role-based scoring (founder correction R3: "everyone is important in
// startups"). Real-time event-sourced via outbox pattern: every
// emitting service writes a ProductivityEvent inside the same
// transaction as its source mutation, guaranteeing the event log is
// always in sync with reality.
//
// Architecture:
//   Source mutation + outbox row  →  Prisma transaction
//   ProductivityEvent rows         →  poll'd by scoreRecomputeWorker
//   Per-user debounced recompute   →  upserts EmployeeProductivityScore
//   Dashboard reads pre-computed   →  React Query 30s refetch
//
// See ~/.gstack/projects/saipreethamvudutha-Exargen_Command_Center/
//   preetham-fix-pulse-probe-precompiled-and-encoding-design-*.md
// for the full design rationale, weights, and rollout schedule.
// ────────────────────────────────────────────────────────────────────

enum ProductivitySignal {
  STANDUP // daily standup discipline (daily_updates)
  EXECUTION // tasks closed (tasks)
  CODE // git contribution (github_webhook_events)
  COMMUNICATION // comments + mentions (comments)
  PRESENCE // clock hours + Pulse active + login discipline
  DEEP_WORK // sustained focus blocks + productive-app ratio
  DEVICE_HYGIENE // security posture + patches + agent uptime
}

enum ProductivityCadence {
  DAILY
  WEEKLY
  MONTHLY
}

enum ScoreBand {
  HIGH // >= thresholdHigh (default 75) → "exceeds expectations"
  MEDIUM // >= 40 < thresholdHigh         → "meets expectations"
  LOW // < 40                          → "needs attention"
}

// Display-only self-identification. NEVER read by the scorer (R3).
enum SelfRole {
  ENGINEER
  PM
  DESIGNER
  OPS
  SALES
  FOUNDER
  OTHER
}

// Append-only event log feeding the productivity scorers.
//
// Every domain mutation that contributes to a score writes one row
// here inside the SAME Prisma transaction as the source mutation
// (outbox pattern). This guarantees:
//   (a) No events are dropped on rollback.
//   (b) No after-commit hooks needed.
//   (c) Replaying the log reproduces the score exactly.
//
// The scoreRecomputeWorker polls this table for unprocessed rows
// (processedAt IS NULL) every ~5s, debounces per-user to 60s, runs
// the scorers over the rolling 30-day window, and upserts
// EmployeeProductivityScore rows for the current daily/weekly/monthly
// windows. Processed rows are kept for audit (13-month retention) and
// then rolled up to per-week aggregates before raw payload deletion.
model ProductivityEvent {
  id          String             @id @default(uuid())
  userId      String
  user        User               @relation("ProductivityEventUser", fields: [userId], references: [id], onDelete: Cascade)
  signal      ProductivitySignal
  eventType   String             @db.VarChar(64) // e.g. 'standup.submitted', 'task.closed', 'pr.merged'
  occurredAt  DateTime // when the underlying action happened (source-of-truth time)
  recordedAt  DateTime           @default(now()) // when we inserted this row
  processedAt DateTime? // null = unprocessed; non-null = consumed by worker
  rawPayload  Json // exact input that fed the score (for audit + replay)
  scoreDelta  Decimal?           @db.Decimal(6, 2) // contribution to sub-score; null = computed by scorer at recompute time
  gamingFlag  String?            @db.VarChar(64) // non-null = filtered by a gaming guard (e.g. 'standup_too_short')
  source      String             @db.VarChar(32) // 'daily_updates', 'tasks', 'github', 'comments', 'pulse_agent', 'clock_sessions', 'device_snapshots'
  sourceId    String             @db.VarChar(128) // id in the source system, used for de-dupe

  // De-dupe key: replaying the same source mutation must not produce a
  // duplicate event. Different event_types from the same source row
  // (e.g. 'pr.opened' and 'pr.merged' both keyed to the same PR id) are
  // allowed.
  @@unique([source, sourceId, eventType], name: "productivity_events_dedupe_key")
  // For window-aggregate queries: "all of user X's events between T1 and T2".
  @@index([userId, occurredAt])
  // For the worker poller: "give me the oldest unprocessed events".
  @@index([processedAt, recordedAt])
  // For per-signal aggregates.
  @@index([signal, occurredAt])
  @@map("productivity_events")
}

// Computed score rows. One per (user, window, cadence). Upserted by
// the scoreRecomputeWorker on each debounced recompute.
//
// signalScores, rawBreakdown, and flags are JSONB so the schema can
// evolve as new signals come online without migrations. The
// 3-layer audit trail (composite → per-signal → raw inputs) is fully
// reconstructable from these three columns alone.
model EmployeeProductivityScore {
  id                     String              @id @default(uuid())
  userId                 String
  user                   User                @relation("EmployeeProductivityScoreUser", fields: [userId], references: [id], onDelete: Cascade)
  // Window boundaries in the user's local timezone (calendar day).
  // Storage is date-only; the user's TZ is read at compute time.
  windowStart            DateTime            @db.Date
  windowEnd              DateTime            @db.Date
  cadence                ProductivityCadence
  // 0.00 - 100.00; clamped after weight + gaming penalty.
  compositeScore         Decimal             @db.Decimal(5, 2)
  band                   ScoreBand
  // { "STANDUP": 80, "EXECUTION": 65, "CODE": 92, "COMMUNICATION": 70,
  //   "PRESENCE": 75, "DEEP_WORK": 82, "DEVICE_HYGIENE": 95 }
  signalScores           Json
  // Counts that fed each signal score, for the breakdown UI:
  // { "STANDUP": { "substantive_standups": 18, "working_days": 20 },
  //   "EXECUTION": { "tasks_closed": 12, "points": 47 }, ... }
  rawBreakdown           Json
  // Calibration metadata: PTO days, partial-day flags, gaming flags
  // that fired, burnout warnings. JSONB so we can add new flag types
  // without migrations.
  flags                  Json
  computedAt             DateTime            @default(now())
  // Number of ProductivityEvents that fed this calculation. For audit
  // queries: "what data did this score actually see?".
  computedFromEventCount Int                 @default(0)

  // One score row per (user, window, cadence). Recompute does UPSERT.
  @@unique([userId, windowStart, windowEnd, cadence], name: "employee_productivity_scores_window_key")
  // For the dashboard's "show me everyone's current week" query.
  @@index([cadence, windowStart])
  @@index([userId, cadence])
  @@map("employee_productivity_scores")
}

// Append-only history of universal weight sets. Every PATCH from the
// SUPER_ADMIN admin UI creates a new row; the row with the latest
// effectiveFrom timestamp is the active set. We never UPDATE rows here
// — full audit trail of "what weights were active when this score was
// computed" is reconstructable from this table alone.
//
// Per R3: this is single-set (no role-keyed table). Per R5 the seeded
// initial row uses:
//   STANDUP=0.13, EXECUTION=0.22, CODE=0.10, COMMUNICATION=0.10,
//   PRESENCE=0.18, DEEP_WORK=0.22, DEVICE_HYGIENE=0.05
// All weights sum to 1.00; a CHECK constraint enforces this at the DB
// level.
model UniversalWeightSet {
  id              String   @id @default(uuid())
  // { "STANDUP": 0.13, "EXECUTION": 0.22, "CODE": 0.10, "COMMUNICATION": 0.10,
  //   "PRESENCE": 0.18, "DEEP_WORK": 0.22, "DEVICE_HYGIENE": 0.05 }
  // Application-level invariant: sum(weights.values()) == 1.0 ± 0.01
  weights         Json
  // Tunable per-signal anchors (e.g. weekly task-point baseline).
  // Decoupled from weights so SUPER_ADMIN can recalibrate baselines
  // without touching weights and vice-versa.
  signalBaselines Json
  // Score band thresholds, expressed in 0-100 composite-score space.
  thresholdHigh   Int      @default(75)
  thresholdLow    Int      @default(40)
  // When this weight set started being applied. Append-only history;
  // we never UPDATE. New PATCH = new row with a later effectiveFrom.
  effectiveFrom   DateTime @default(now())
  updatedBy       String
  updatedByUser   User     @relation("UniversalWeightSetUpdater", fields: [updatedBy], references: [id])
  // SUPER_ADMIN audit memo: why this change was made.
  changeNote      String?  @db.Text

  // Active set = max(effectiveFrom). Query pattern is fast.
  @@index([effectiveFrom(sort: Desc)])
  @@map("universal_weight_sets")
}

// Optional self-identified role + bio for an employee. DISPLAY ONLY —
// the productivity scorer NEVER reads selfRole. Per R3 founder
// correction: universal weights, no role-based scoring.
//
// customWeightOverrides is an emergency escape hatch: SUPER_ADMIN may
// override the universal weights for one individual in edge cases
// (e.g. new-hire ramp, role transition month). Audit-logged. Default
// null = use universal weights.
model EmployeeProfile {
  userId                String    @id
  user                  User      @relation("EmployeeProfileUser", fields: [userId], references: [id], onDelete: Cascade)
  selfRole              SelfRole?
  bio                   String?   @db.Text
  // { "STANDUP": 0.15, ... } overrides for THIS user only. Must sum to
  // 1.0 if non-null. SUPER_ADMIN-only edit, audit-logged.
  customWeightOverrides Json?
  customWeightSetAt     DateTime?
  customWeightSetBy     String?
  updatedAt             DateTime  @updatedAt

  @@map("employee_profiles")
}

// ────────────────────────────────────────────────────────────────────
// GitHub webhook audit log (Wave 3, PR #33 — CODE signal)
//
// Captures the raw webhook delivery for replay + reconciliation. The
// scoreRecomputeWorker (Wave 5) cross-checks this table against
// productivity_events to detect any GitHub deliveries that fired the
// HMAC gate but failed to produce a productivity event (programming
// bug, schema drift, etc.).
//
// Retention: 90 days raw. After that, the derived productivity_events
// rows are the audit trail; we don't need to keep the full payload.
// ────────────────────────────────────────────────────────────────────

model GithubWebhookEvent {
  id            String   @id @default(uuid())
  // X-GitHub-Delivery header. UUID. Used as the de-dupe key —
  // re-deliveries of the same event no-op on the second insert.
  deliveryId    String   @unique @db.VarChar(64)
  // X-GitHub-Event header. e.g. 'push', 'pull_request', 'pull_request_review'.
  eventType     String   @db.VarChar(32)
  // GitHub-side action (PR.action: 'opened'/'closed'/'edited' etc.).
  // Null for events without an action field (e.g. push).
  action        String?  @db.VarChar(32)
  // Org/repo slug for the delivery, e.g. 'Exargen-AI/exargen-command-center'.
  repo          String?  @db.VarChar(255)
  // Login of the actor who triggered the event. Lowercased for join
  // against User.githubLogin.
  actorLogin    String?  @db.VarChar(64)
  // Whether the actor was identified as a bot at write time. Stored
  // separately so reconciliation queries don't re-derive bot status.
  actorIsBot    Boolean  @default(false)
  // Full raw payload as received from GitHub. JSONB so derived
  // queries can filter without re-parsing.
  rawPayload    Json
  // Number of productivity_events produced from this delivery. 0 if
  // no users matched or the event type was ignored.
  eventsEmitted Int      @default(0)
  receivedAt    DateTime @default(now())

  @@index([eventType, receivedAt])
  @@index([actorLogin, receivedAt])
  @@index([receivedAt])
  @@map("github_webhook_events")
}
