/// Per-product custom field definition. Lets each project track its own
/// domain-specific structured data without schema migrations — Furix tracks
/// CVE/CVSS, RozCar tracks KYC status, ManaCalendar tracks Tithi, etc.
/// Values are stored as a JSON map on Task.customFields keyed by definition.key.
enum CustomFieldType {
  TEXT
  NUMBER
  SELECT
  DATE
  URL
  BADGE
}

model CustomFieldDefinition {
  id        String          @id @default(uuid())
  projectId String
  /// Human-readable label shown on inputs and as the column header.
  name      String
  /// Stable machine key used in the Task.customFields JSON map. Must be
  /// unique within a project, lowercase + underscores by convention.
  key       String
  fieldType CustomFieldType
  /// Type-specific config: SELECT options, NUMBER min/max, BADGE color,
  /// TEXT multiline flag, etc. Schema is type-checked at the service layer.
  config    Json            @default("{}")
  required  Boolean         @default(false)
  /// Display order on the task detail panel. Lower = higher.
  order     Int             @default(0)
  /// Optional help text shown under the input.
  hint      String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, key])
  @@index([projectId, order])
  @@map("custom_field_definitions")
}

// CMS Media Assets
