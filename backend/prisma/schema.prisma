generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───

enum UserRole {
  SUPER_ADMIN
  ADMIN
  PRODUCT_MANAGER
  ENGINEER
  CLIENT
  TESTING
}

// Orthogonal axis to UserRole. Most policy lives on `role`; `userType`
// captures the "is this caller a human or an autonomous agent?" question
// for the small set of policies where the distinction matters (e.g.,
// agents cannot transition tasks to Done — that's reserved for human
// review). Default is HUMAN; agents are explicitly minted by Super Admin.
//
// History: this enum + the 6 agent_* columns on User were added by
// migration 20260509000000_agent_users (PR #63, Slice 1) and then
// accidentally dropped from schema.prisma by a later merge. The DB still
// has the columns; this restores the schema-side source of truth.
enum UserType {
  HUMAN
  AGENT
}

enum ProjectCategory {
  FLAGSHIP
  PLATFORM
  B2C_SMB
  PASSION
  CONSULTING
  SOCIAL_IMPACT
}

enum ProjectPhase {
  IDEA
  ARCHITECTURE
  DEVELOPMENT
  TESTING
  LIVE
  MAINTENANCE
}

enum HealthStatus {
  GREEN
  YELLOW
  RED
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum TaskPriority {
  P0
  P1
  P2
  P3
}

enum MilestoneStatus {
  UPCOMING
  COMPLETED
  MISSED
}

enum TaskType {
  FEATURE
  BUG
  CHORE
  SPIKE
}

enum SprintStatus {
  PLANNING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum EpicStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum DecisionStatus {
  PROPOSED
  ACCEPTED
  SUPERSEDED
}

enum DeliverableStatus {
  PENDING
  IN_PROGRESS
  DELIVERED
  SIGNED_OFF
  REJECTED
}

// ─── Project Documents (S3-backed) ───

// What kind of reference material this document is. Drives category
// filters in the UI and helps the agent decide which doc to fetch when
// it sees the knowledge-pack listing. Adding a new value is additive —
// existing docs default to OTHER on a tag-less upload, and the FE renders
// "Other" as a fallback. Keep the set small; if it grows past ~10 we'll
// switch to a free-form tag.
enum DocCategory {
  SPEC
  DESIGN
  CONTRACT
  REFERENCE
  RUNBOOK
  SECURITY
  OTHER
}

// PENDING — DB row created via presigned-upload but the client hasn't
// confirmed the S3 PUT completed. Filtered out of list endpoints until
// confirmed. Cleaned up by a daily cron if older than 24h.
//
// READY — uploaded + confirmed, listable.
//
// DELETED — soft-deleted. The S3 object is removed asynchronously
// (Phase 2 of the docs feature adds the cleanup worker); the row stays
// for audit. Filtered out of every endpoint except the admin audit view.
enum DocStatus {
  PENDING
  READY
  DELETED
}

// ─── MODELS ───

model User {
  id               String    @id @default(uuid())
  name             String
  email            String    @unique
  passwordHash     String
  role             UserRole  @default(ENGINEER)
  company          String?
  // S3 object key of the user's uploaded profile photo (2026-06). NULL until
  // they upload one. We store the KEY, not a URL — the bucket is private, so
  // the API hands the client a fresh presigned GET URL (`avatarUrl`) on each
  // auth response. The key never leaves the server.
  avatarKey        String?
  isActive         Boolean   @default(true)
  isSeedData       Boolean   @default(false)
  lastLoginAt      DateTime?
  // Bumped on logout-everywhere, password change, role change. Embedded in
  // every issued JWT so a stolen token is invalidated server-side without
  // waiting for natural expiry.
  tokenVersion     Int       @default(0)
  // Per-account brute-force lockout. failedLoginCount resets on success or
  // when lockedUntil elapses; lockedUntil short-circuits bcrypt in login().
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?
  // ─── Agent visibility allowlist (2026-06-01) ───
  // AI agents (userType = AGENT) and everything they touch — tasks
  // assigned to them, their comments, their activity-feed entries — are
  // hidden from regular users. They're visible only to SUPER_ADMIN
  // (implicitly) and to users with this flag set. SUPER_ADMIN manages
  // the allowlist via a multi-select; only SUPER_ADMIN can flip this
  // field (enforced in `userService.updateUser`). Default false so no
  // one outside SUPER_ADMIN sees agents until explicitly granted.
  // Inert on SUPER_ADMIN rows (they always see agents).
  canViewAgents    Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  projectMemberships      ProjectMember[]
  assignedTasks           Task[]                   @relation("TaskAssignee")
  createdTasks            Task[]                   @relation("TaskCreator")
  // Tasks currently waiting on this user to review (set by the explicit
  // "Request review" action; cleared on the review decision).
  reviewingTasks          Task[]                   @relation("TaskReviewer")
  requestedReviews        Task[]                   @relation("TaskReviewRequester")
  comments                Comment[]
  decisions               Decision[]
  statusUpdates           StatusUpdate[]
  activities              Activity[]
  dailyUpdates            DailyUpdate[]
  statusChanges           TaskStatusHistory[]
  notifications           Notification[]
  projectAcknowledgments  ProjectAcknowledgment[]
  signedOffDeliverables   Deliverable[]            @relation("DeliverableSignedOff")
  createdTaskLinks        TaskLink[]
  refreshTokens           RefreshToken[]
  agentRuns               AgentRun[]               @relation("AgentRunAgent")
  uploadedDocuments       ProjectDocument[]        @relation("ProjectDocumentUploader")
  taskSubscriptions       TaskSubscription[]
  sentNudges              TaskNudge[]              @relation("TaskNudgeSender")
  notificationPreferences NotificationPreference[]
  // 2026-05-23 Layer 2 / agent control plane. Cascade-delete on user
  // deletion so stale dedup rows can't outlive their owner.
  idempotencyKeys         IdempotencyKey[]

  // GitHub login mapping (used by the GitHub integration). Stored
  // lowercased + unique so a typo'd casing doesn't multi-credit one
  // human. Null until populated.
  githubLogin String? @unique

  // ─── Agent platform ───
  // For HUMAN users (the vast majority) all agent-* fields stay null/default.
  // For AGENT users (e.g. Manjari): role still drives RBAC; agentRole is a
  // free-text label ("autonomous-engineer", "autonomous-pm", ...) that
  // appears in admin UI but has no permission consequence.
  // agentSystemPromptPath records where the agent's CLAUDE.md / skills
  // live on the host filesystem (informational only — Command Center
  // does not read it). Budget fields let the runtime enforce a per-agent
  // monthly cost ceiling.
  //
  // Ships with migration 20260509000000_agent_users (PR #63). These
  // schema lines were accidentally dropped by a later merge; this
  // restores the source-of-truth without changing the DB shape.
  userType                   UserType @default(HUMAN)
  agentRole                  String?
  agentSystemPromptPath      String?
  agentBudgetMonthlyUsdCents Int?
  agentBudgetUsedUsdCents    Int      @default(0)
  agentActive                Boolean  @default(true)

  @@map("users")
}

// Server-side refresh-token state. Each successful login mints one row; each
// /auth/refresh rotates it (mark old.revokedAt, create a new row whose
// `replacedById` chains back). Reuse of a revoked token triggers a chain-wide
// revoke — a strong signal that the token was stolen.
model RefreshToken {
  id           String    @id @default(uuid())
  userId       String
  // Revoked tokens are kept (not deleted) so reuse detection can flag them.
  revokedAt    DateTime?
  replacedById String?   @unique
  expiresAt    DateTime
  // Forensic context. Useful for "list active sessions" later, and for
  // identifying odd traffic patterns when a chain is compromised.
  userAgent    String?
  ip           String?
  createdAt    DateTime  @default(now())

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedBy     RefreshToken?  @relation("TokenChain", fields: [replacedById], references: [id])
  replacedTokens RefreshToken[] @relation("TokenChain")

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Project {
  id                String          @id @default(uuid())
  name              String
  slug              String          @unique
  description       String?         @db.Text
  clientDescription String?         @db.Text
  category          ProjectCategory
  phase             ProjectPhase    @default(IDEA)
  healthStatus      HealthStatus    @default(GREEN)
  autoHealth        Boolean         @default(true)
  tags              String[]
  startDate         DateTime?
  targetDate        DateTime?
  taskCounter       Int             @default(0)
  isSeedData        Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  members                ProjectMember[]
  tasks                  Task[]
  sprints                Sprint[]
  epics                  Epic[]
  milestones             Milestone[]
  decisions              Decision[]
  deliverables           Deliverable[]
  comments               Comment[]
  statusUpdates          StatusUpdate[]
  activities             Activity[]
  acknowledgments        ProjectAcknowledgment[]
  customFieldDefinitions CustomFieldDefinition[]
  githubIntegration      ProjectGitHubIntegration?
  documents              ProjectDocument[]
  products               Product[]

  @@map("projects")
}

// ─── Product (PR C feature #6) ───
//
// A discrete shipping unit inside a Project. The motivating use case:
// project "Acme Platform" can carry Products like "Customer Web App",
// "Admin Console", "Mobile App". Tasks optionally belong to a Product
// (the productId on Task is nullable — project-level setup tasks
// legitimately have no product).
//
// Why an additive model rather than overloading Epic:
//   - Products are LONG-LIVED. Epics are sprint-scoped slices of work
//     inside a product.
//   - Products are visible to clients (the team explicitly shows the
//     client "here are the things we're shipping for you"); epics are
//     internal sprint vocabulary.
//   - Clients can submit bugs scoped to a Product without us having
//     to expose the entire epic taxonomy.
//
// Slug is per-project unique (not globally) so two unrelated projects
// can each have a "mobile" product without colliding.
model Product {
  id          String        @id @default(uuid())
  projectId   String
  name        String
  // URL-safe identifier — used for /projects/:id/products/:slug.
  // Project-scoped unique so "mobile" can co-exist across projects.
  slug        String
  description String?       @db.Text
  status      ProductStatus @default(ACTIVE)
  // Admin-controlled display order. The list view sorts by this then
  // name so a freshly-renamed product doesn't visually re-shuffle.
  order       Int           @default(0)
  // Optional visual cues. `color` is a hex string ("#8b5cf6"); `icon`
  // is a lucide-react component name resolved client-side. Both
  // nullable so creating a product doesn't force a styling decision.
  color       String?
  icon        String?
  archivedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@unique([projectId, slug])
  @@index([projectId])
  @@index([projectId, status])
  @@map("products")
}

enum ProductStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

// One row per project that's wired up to a GitHub repo. A project can be
// linked to at most one repo today; if a team needs more we'd convert this
// to a 1-to-many. The webhook secret is what we HMAC-verify incoming
// payloads against — never returned in API responses (admin sets it once,
// pastes it into GitHub, then it lives only here).
model ProjectGitHubIntegration {
  id                 String    @id @default(uuid())
  projectId          String    @unique
  // Format `owner/repo`. We split on `/` at the route layer; storing both
  // halves separately makes querying cleaner.
  repoOwner          String
  repoName           String
  // The branch agent PRs target by default (the repo's default branch).
  defaultBranch      String    @default("main")
  webhookSecret      String
  // When true, a merged PR carrying `Closes <TASK-ID>` automatically moves
  // the task to DONE (still gated by AC done-gate). Off by default — admins
  // opt in once they trust the linkage.
  autoCloseOnMerge   Boolean   @default(false)
  // Last SUCCESSFUL webhook delivery (event accepted + processed without
  // throwing). Surfaced in the settings UI as "last heard from GitHub: X
  // minutes ago". Round 2 follow-up #11: previously this was stamped at the
  // start of the handler, before processing — meaning a string of failing
  // webhooks (DB down, race with disconnect, etc.) still showed "last
  // received 30s ago" and admins wouldn't notice the integration was broken.
  lastWebhookAt      DateTime?
  // Last FAILED webhook delivery. Lets the settings UI flag a yellow/red
  // pill when the latest activity was an error, even if a much-older
  // success exists. Reset implicitly on the next successful delivery (we
  // just stop updating it; the timestamp gap tells the story).
  lastWebhookErrorAt DateTime?
  // Short message describing the latest error. Truncated to keep this
  // column small; full traceback goes to server logs.
  lastWebhookError   String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_github_integrations")
}

// A project-scoped document stored on S3. Surface for non-code project
// context: specs, design briefs, contracts, runbooks, security policies,
// reference PDFs. Two consumers:
//
//   - Humans (admin UI, client portal Documents tab): upload + browse +
//     download. Upload via presigned S3 PUT URL so file bytes never
//     traverse the API server — keeps Railway's request size limits out
//     of the picture and lets 50MB+ uploads work cleanly.
//
//   - Agents (Manjari & co.): get a list of available documents through
//     the knowledge-pack endpoint (metadata only — title, description,
//     category, sizeBytes — no content). On a hit, they fetch via a
//     presigned GET URL through the agent-only download endpoint. The
//     agent never sees the bucket name or AWS credentials; it sees a
//     short-lived URL the backend issued just for it.
//
// `s3Key` is the unique object identifier within the bucket. Format:
// `projects/<projectId>/<docId>/<filename>` — keeps project-level
// directory listings cheap, and prefixing by docId lets us drop a doc
// without touching siblings even when filenames collide.
//
// `status` flow:
//   - PENDING (created at presigned-upload time; client hasn't confirmed
//     S3 PUT yet)
//   - READY  (confirmed; appears in list + KP)
//   - DELETED (soft delete; S3 object removed by async cleanup worker)
model ProjectDocument {
  id          String      @id @default(uuid())
  projectId   String
  title       String
  description String?     @db.Text
  category    DocCategory @default(OTHER)

  // Bucket name is stored on the row so a future move (e.g. cold-storage
  // tier) doesn't require a migration — the row just points at wherever
  // the bytes ended up. App code reads env.S3_DOCUMENTS_BUCKET on new
  // uploads but trusts the per-row value on download.
  s3Bucket String
  s3Key    String @unique

  filename    String // original upload filename, for the download Content-Disposition
  contentType String // canonical MIME
  sizeBytes   Int

  status       DocStatus @default(PENDING)
  uploadedById String
  uploadedAt   DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  // Soft-delete tombstone; set when status transitions to DELETED.
  deletedAt    DateTime?

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation("ProjectDocumentUploader", fields: [uploadedById], references: [id])

  // Most lookups filter by project + status (=READY), and order by
  // uploadedAt desc. The compound index covers the common path.
  @@index([projectId, status, uploadedAt(sort: Desc)])
  @@index([uploadedById])
  @@map("project_documents")
}

model ProjectMember {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  role      UserRole
  joinedAt  DateTime @default(now())

  // Per-project "full access" grant (2026-06-02). When true on a CLIENT
  // member, that client sees the FULL internal view of THIS project only —
  // every task (clientVisible=false included), decisions, and internal
  // task comments — instead of the stripped client-visible subset. Scoped
  // to the membership so a client on multiple projects can have full
  // access to one and the normal portal view of another. Only SUPER_ADMIN
  // can flip it (enforced in project.service.setMemberFullAccess). Inert
  // on staff roles, who already see internal work via their role. This is
  // the ONLY full-client-access mechanism — the old blunt global
  // User.extendedClientAccess flag was retired (2026-06-02).
  fullAccess Boolean @default(false)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  // Membership-by-project lookup is the hot path for projectAccess on every
  // authenticated request. The unique index on (userId, projectId) only
  // serves the leading column (userId) — adding a (projectId) index lets
  // membership lookups by project hit a btree directly (QA finding #58).
  @@index([projectId])
  @@map("project_members")
}

model Task {
  id                  String       @id @default(uuid())
  projectId           String
  taskNumber          Int          @default(0)
  title               String
  description         String?      @db.Text
  taskType            TaskType     @default(FEATURE)
  status              TaskStatus   @default(BACKLOG)
  priority            TaskPriority @default(P2)
  storyPoints         Int?
  sprintId            String?
  epicId              String?
  // Optional milestone scoping. Lets tasks roll up to a specific
  // milestone for "is this milestone on track?" calculations + the
  // client-facing milestone progress bar. NULL is "this task isn't
  // associated with a single milestone" — the common case for
  // sprint-level work and chore tasks. Milestone deletion cascades
  // to NULL here (FK rule below) so deleting a milestone doesn't drop
  // any task history.
  milestoneId         String?
  // Optional product scoping (PR C feature #6). NULL is "project-level
  // work that doesn't fit a single product" — admin setup, contracts,
  // cross-cutting platform work. Product deletion cascades to NULL
  // here (FK rule below) so archiving a product preserves task history.
  productId           String?
  assigneeId          String?
  // Mixed assignment: when assigneeId is null and agentPoolRole is set, the
  // task is open for ANY agent whose `User.agentRole` matches — a capability
  // pool rather than a named assignee. The agent control-plane picker claims
  // it atomically on pickup (sets assigneeId), so two agents can't both grab
  // it. Ignored once assigneeId is set.
  agentPoolRole       String?
  creatorId           String
  dueDate             DateTime?
  labels              String[]
  subtasks            Json         @default("[]")
  acceptanceCriteria  Json         @default("[]")
  customFields        Json         @default("{}")
  isBlocked           Boolean      @default(false)
  blockerNote         String?
  clientVisible       Boolean      @default(false)
  // True when the task originated from a CLIENT submitting via their
  // portal kanban (forced clientVisible=true + status=BACKLOG at create
  // time; team triages from there). Stored as an explicit boolean so
  // "incoming requests for this project" stays cheap to query and the
  // workflow provenance survives any future role flip on the creator.
  clientRequested     Boolean      @default(false)
  // Review workflow (PR B feature #5). Set when a task is handed off
  // via the explicit "Request review" action. assigneeId stays put
  // (the original worker keeps the credit + workload attribution);
  // reviewerId carries the current ball. Cleared on review-decision
  // (approve → DONE, request_changes → IN_PROGRESS). Reviewer can be
  // any project member, including the client — that's the whole point
  // of replacing "swap the assignee" with an explicit reviewer field.
  reviewerId          String?
  reviewRequestedAt   DateTime?
  reviewRequestedById String?
  sortOrder           Int          @default(0)
  isSeedData          Boolean      @default(false)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  project          Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint           Sprint?             @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  epic             Epic?               @relation(fields: [epicId], references: [id], onDelete: SetNull)
  milestone        Milestone?          @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  product          Product?            @relation(fields: [productId], references: [id], onDelete: SetNull)
  assignee         User?               @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator          User                @relation("TaskCreator", fields: [creatorId], references: [id])
  reviewer         User?               @relation("TaskReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  reviewRequester  User?               @relation("TaskReviewRequester", fields: [reviewRequestedById], references: [id], onDelete: SetNull)
  comments         Comment[]
  statusHistory    TaskStatusHistory[]
  agentRuns        AgentRun[]
  dailyUpdateTasks DailyUpdateTask[]
  linksFrom        TaskLink[]          @relation("LinksFrom")
  linksTo          TaskLink[]          @relation("LinksTo")
  externalLinks    TaskExternalLink[]
  subscriptions    TaskSubscription[]
  nudges           TaskNudge[]

  @@unique([projectId, taskNumber])
  @@index([projectId, status])
  @@index([assigneeId])
  // Agent-pool pickup queries filter on (assigneeId IS NULL, agentPoolRole, status).
  @@index([agentPoolRole])
  // "What's assigned to X in project Y" is the engineer-dashboard query.
  // The bare `assigneeId` index works but Postgres has to filter projectId
  // post-fetch; the composite makes that direct (QA finding #44).
  @@index([projectId, assigneeId])
  @@index([sprintId])
  @@index([epicId])
  // Roll-up query: "all tasks under this milestone" — used by the
  // per-milestone progress bar + future per-milestone forecast.
  @@index([milestoneId])
  @@index([projectId, clientVisible])
  // "Incoming client requests" is its own dashboard slice — index it the
  // same way as clientVisible so the triage view is fast even at 10k tasks.
  @@index([projectId, clientRequested])
  // "Tasks waiting on me to review" (dashboard slice) + scoped lookups.
  @@index([reviewerId])
  @@index([projectId, reviewerId])
  // Product scoping (PR C feature #6) — "all tasks in this product" is
  // the hot query on the product detail page kanban.
  @@index([productId])
  @@index([projectId, productId])
  @@index([creatorId])
  @@index([reviewRequestedById])
  @@map("tasks")
}

// Outbound link from a task to a record in another system (today: GitHub PRs;
// future: Slack threads, Linear issues, support tickets). Kept as a single
// flat table rather than per-system because the read pattern — "show
// everything attached to this task" — needs one query, and the row count per
// task is always small (1–3 PRs typical).
model TaskExternalLink {
  id           String                @id @default(uuid())
  taskId       String
  kind         TaskExternalLinkKind
  // The provider's stable identifier. For GitHub PRs: `<owner>/<repo>#<num>`.
  // The unique guarantees we never double-link the same PR to the same task,
  // so re-deliveries / replays of the same webhook are idempotent.
  externalId   String
  url          String
  title        String?
  state        TaskExternalLinkState @default(OPEN)
  // PR author display name + avatar URL — captured once at link time so the
  // task page doesn't need to call out to GitHub on every render.
  authorName   String?
  authorAvatar String?
  openedAt     DateTime?
  mergedAt     DateTime?
  closedAt     DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, kind, externalId])
  @@index([taskId])
  @@map("task_external_links")
}

enum TaskExternalLinkKind {
  GITHUB_PR
}

enum TaskExternalLinkState {
  OPEN
  MERGED
  CLOSED
}

enum TaskLinkType {
  BLOCKS // fromTask blocks toTask  (inverse view: toTask is BLOCKED_BY fromTask)
  RELATES_TO // peer relationship; we still store directionally for audit
  DUPLICATES // fromTask duplicates toTask  (inverse view: toTask is DUPLICATED_BY fromTask)
  // PR C feature #7 — bug triage spin-off. `fromTask was spawned from
  // toTask`. We add a dedicated kind (rather than reusing RELATES_TO)
  // so the slide-over can render parent/child semantics correctly:
  // the parent bug shows "Spawned tasks (3)", each child shows
  // "Spawned from <bug title>".
  SPAWNED_FROM
}

/// Directional link between two tasks within the same project.
/// BLOCKS / DUPLICATES are asymmetric (rendered as "Blocks"/"Blocked by",
/// "Duplicates"/"Duplicated by"); RELATES_TO is symmetric.
model TaskLink {
  id          String       @id @default(uuid())
  fromTaskId  String
  toTaskId    String
  type        TaskLinkType
  createdById String
  createdAt   DateTime     @default(now())

  fromTask  Task @relation("LinksFrom", fields: [fromTaskId], references: [id], onDelete: Cascade)
  toTask    Task @relation("LinksTo", fields: [toTaskId], references: [id], onDelete: Cascade)
  createdBy User @relation(fields: [createdById], references: [id])

  @@unique([fromTaskId, toTaskId, type])
  @@index([fromTaskId])
  @@index([toTaskId])
  @@index([createdById])
  @@map("task_links")
}

// ─── TaskSubscription ──────────────────────────────────────────────
//
// Users follow a task to receive notifications on new comments + on
// significant edits (title, description, priority, due-date, status).
// Distinct from project membership — a user can be in a project but
// only subscribed to a few tasks within it.
//
// `source` records WHY a subscription exists so we can render that
// honestly in the UI ("auto-subscribed because you were assigned")
// and so the auto-subscribe machinery can re-add a row only when
// it should — e.g. if a user manually unsubscribes from a task they
// were auto-subscribed to, we don't re-add them next time the
// assignment changes (their unsubscribe is intentional).
enum TaskSubscriptionSource {
  AUTO_ASSIGNEE
  AUTO_REVIEWER
  AUTO_CREATOR
  AUTO_MENTIONED
  MANUAL
}

model TaskSubscription {
  id        String                 @id @default(uuid())
  taskId    String
  userId    String
  source    TaskSubscriptionSource
  createdAt DateTime               @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One subscription per (task, user) — re-subscribe is idempotent.
  @@unique([taskId, userId])
  @@index([taskId])
  @@index([userId])
  @@map("task_subscriptions")
}

// ─── TaskNudge ─────────────────────────────────────────────────────
//
// Records every nudge sent on a task. Used to enforce the per-
// (task, sender) 24h cooldown — prevents nudge spam. Also serves as
// a lightweight audit trail of "who poked whom about what."
//
// We don't add a `recipient` column — the recipient is implicitly the
// task's assignee at nudge-time. If the assignee changes, future
// nudges go to the new assignee; historical rows still reflect when
// the nudge was sent.
model TaskNudge {
  id        String   @id @default(uuid())
  taskId    String
  senderId  String
  message   String?  @db.Text
  createdAt DateTime @default(now())

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  sender User @relation("TaskNudgeSender", fields: [senderId], references: [id])

  // Hot query: "has THIS user nudged THIS task in the last 24h?" —
  // the cooldown enforcement. Composite is the right shape.
  @@index([taskId, senderId, createdAt])
  @@index([senderId])
  @@map("task_nudges")
}

model Sprint {
  id         String       @id @default(uuid())
  projectId  String
  // Optional FK to the Epic that owns this sprint. Set by the markdown
  // ingestion path when a Sprint is nested inside an Epic; null for
  // sprints created via the in-app planner (which today is project-flat).
  // Lets dedup distinguish "Epic A's Sprint 1" from "Epic B's Sprint 1"
  // (QA I-C2). onDelete: SetNull so deleting an epic detaches its sprints
  // but doesn't drop them.
  epicId     String?
  name       String
  number     Int
  goal       String?      @db.Text
  startDate  DateTime
  endDate    DateTime
  status     SprintStatus @default(PLANNING)
  retroNotes Json?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  epic    Epic?   @relation(fields: [epicId], references: [id], onDelete: SetNull)
  tasks   Task[]

  @@unique([projectId, number])
  @@index([projectId, status])
  @@index([epicId])
  @@map("sprints")
}

model Epic {
  id          String     @id @default(uuid())
  projectId   String
  title       String
  description String?    @db.Text
  color       String     @default("#6366f1")
  status      EpicStatus @default(OPEN)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]
  sprints Sprint[]

  @@index([projectId])
  @@map("epics")
}

model Milestone {
  id            String          @id @default(uuid())
  projectId     String
  title         String
  description   String?         @db.Text
  date          DateTime
  status        MilestoneStatus @default(UPCOMING)
  clientVisible Boolean         @default(true)
  isSeedData    Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  comments Comment[]
  // Tasks associated with this milestone. Used by the per-milestone
  // progress aggregator (% complete, story points done/total).
  tasks    Task[]

  @@index([projectId])
  @@map("milestones")
}

model Decision {
  id           String         @id @default(uuid())
  projectId    String
  title        String
  rationale    String         @db.Text
  alternatives String?        @db.Text
  status       DecisionStatus @default(PROPOSED)
  tags         String[]
  createdById  String
  isSeedData   Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id])

  @@index([projectId])
  @@index([createdById])
  @@map("decisions")
}

// Captures the moment a user accepted the confidentiality terms for a specific
// project. One row per (user, project). Stores the snapshot of the agreed text
// + IP + UA so this is a legally-defensible audit record — survives even if the
// boilerplate text changes later.
model ProjectAcknowledgment {
  id               String   @id @default(uuid())
  userId           String
  projectId        String
  acknowledgedAt   DateTime @default(now())
  ipAddress        String?
  userAgent        String?  @db.Text
  acknowledgedText String   @db.Text

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId])
  @@map("project_acknowledgments")
}

// Agreed deliverables for a project — drives the client sign-off workflow.
// Status transitions: PENDING → IN_PROGRESS → DELIVERED → SIGNED_OFF (terminal)
//                                              ↘ REJECTED → IN_PROGRESS
model Deliverable {
  id                 String            @id @default(uuid())
  projectId          String
  title              String
  description        String?           @db.Text
  acceptanceCriteria String?           @db.Text
  status             DeliverableStatus @default(PENDING)
  targetDate         DateTime?
  deliveredAt        DateTime?
  signedOffAt        DateTime?
  signedOffById      String?
  rejectionNote      String?           @db.Text
  sortOrder          Int               @default(0)
  isSeedData         Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  signedOffBy User?   @relation("DeliverableSignedOff", fields: [signedOffById], references: [id])

  @@index([projectId])
  @@index([signedOffById])
  @@map("deliverables")
}

model Comment {
  id          String    @id @default(uuid())
  projectId   String
  taskId      String?
  milestoneId String?
  authorId    String
  content     String    @db.Text
  isSeedData  Boolean   @default(false)
  // Comment subtype discriminator. "plain" = a normal thread comment
  // (the only kind before 2026-06). "story_update" = a structured
  // progress update an engineer posts against the task using the
  // client-facing story template; `storyData` then holds the parsed
  // fields and the FE renders it as a distinct card (not a plain
  // markdown bubble). Stored as a string (not a Prisma enum) so adding
  // future kinds stays an additive, migration-free change.
  kind        String    @default("plain")
  // Structured payload for a "story_update" comment — the parsed
  // template fields (objective, currentTask, reason, impact,
  // designChange, progress, nextStep). NULL for plain comments. The
  // `content` column always holds a plaintext rendering of the same
  // data so search, the productivity scorer, and any kind-unaware
  // reader still degrade gracefully.
  storyData   Json?
  // Set on the first edit (author's own PATCH /comments/:id). Lets the FE
  // render an "edited" badge without confusing it with the auto-bumping
  // `updatedAt` (which moves on any field, including future system-driven
  // updates). Round 2 follow-up R2.
  editedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task      Task?      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  milestone Milestone? @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  author    User       @relation(fields: [authorId], references: [id])

  @@index([projectId])
  @@index([taskId])
  // The client task view pins the latest story update — query is
  // "comments on this task of kind story_update, newest first".
  @@index([taskId, kind])
  @@index([authorId])
  @@index([milestoneId])
  @@map("comments")
}

model StatusUpdate {
  id        String       @id @default(uuid())
  projectId String
  authorId  String
  signal    HealthStatus
  note      String?      @db.Text
  createdAt DateTime     @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id])

  @@index([projectId])
  @@index([authorId])
  @@map("status_updates")
}

model Activity {
  id         String   @id @default(uuid())
  projectId  String?
  userId     String
  action     String
  targetType String?
  targetId   String?
  details    Json?
  createdAt  DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id])

  @@index([projectId])
  @@index([userId])
  @@index([createdAt])
  @@map("activities")
}

// ─── IDEMPOTENCY ─────────────────────────────────────────────────────────
//
// 2026-05-23 — Layer 2 (agent control) infrastructure.
//
// Agents (and any other API client) can send an `Idempotency-Key` header on
// state-changing requests so that a retry after a network failure replays
// the original response instead of creating a duplicate resource. Without
// this, an agent that times out on POST /tasks doesn't know whether the
// task was created — and naively retrying would create two tasks.
//
// Contract (matches Stripe's well-known shape so external developers
// recognize it immediately):
//
//   • Client sends `Idempotency-Key: <opaque-string>` on POST/PATCH/PUT/DELETE.
//   • Server fingerprints the request body + path + method into `requestHash`.
//   • If (userId, key, method, path) exists AND requestHash matches:
//       → REPLAY the stored response (same status + body).
//   • If exists AND requestHash differs:
//       → 422 "Idempotency-Key reused with a different request body"
//   • If absent:
//       → Process normally. AFTER the handler responds, store the response.
//
// TTL: 24 hours. The platform doesn't need longer because (a) any well-
// behaved client retries within seconds, not days, and (b) the storage
// grows linearly with traffic without periodic cleanup. A scheduled
// `deleteMany({ where: { expiresAt: { lt: now } } })` runs daily.
//
// Scoping: per-user. Two different agents using the same key string get
// independent dedupes — keys aren't a global namespace.
model IdempotencyKey {
  id String @id @default(uuid())

  // The composite uniqueness contract — these three together identify a
  // "same request" attempt. Path is stored as the original :param-templated
  // path (not the resolved URL), so the same logical mutation on different
  // resources doesn't collide.
  key    String
  userId String
  method String // HTTP verb, uppercase
  path   String // /api/v1/projects/:id/tasks (templated)

  // SHA-256 of (method + path + sorted body JSON). When a retry comes in,
  // we compare this. Mismatched bodies under the same key are explicit
  // misuse and get a 422.
  requestHash String

  // The stored response we'll replay. statusCode is the HTTP status that
  // was sent; responseBody is the JSON the server returned. Both are
  // captured by the middleware AFTER the handler resolves.
  statusCode   Int
  responseBody Json

  createdAt DateTime @default(now())
  expiresAt DateTime // createdAt + 24h, indexed for cleanup sweep

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key, method, path])
  @@index([userId])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

// ─── DAILY PROGRESS & PRODUCTIVITY ───

model DailyUpdate {
  id          String   @id @default(uuid())
  userId      String
  date        DateTime @db.Date
  summary     String   @db.Text
  blockers    String?  @db.Text
  plans       String?  @db.Text
  hoursWorked Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User              @relation(fields: [userId], references: [id])
  tasks DailyUpdateTask[]

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("daily_updates")
}

model DailyUpdateTask {
  id            String     @id @default(uuid())
  dailyUpdateId String
  taskId        String
  note          String?
  statusBefore  TaskStatus
  statusAfter   TaskStatus

  dailyUpdate DailyUpdate @relation(fields: [dailyUpdateId], references: [id], onDelete: Cascade)
  task        Task        @relation(fields: [taskId], references: [id])

  @@index([dailyUpdateId])
  @@index([taskId])
  @@map("daily_update_tasks")
}

model TaskStatusHistory {
  id         String     @id @default(uuid())
  taskId     String
  fromStatus TaskStatus
  toStatus   TaskStatus
  changedBy  String
  changedAt  DateTime   @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [changedBy], references: [id])

  @@index([taskId])
  @@index([changedBy])
  @@index([changedAt])
  @@map("task_status_history")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

// ─── RBAC CONFIGURATION ───

model Permission {
  id          String  @id @default(uuid())
  key         String  @unique
  label       String
  category    String
  description String?

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  role         UserRole
  permissionId String
  granted      Boolean  @default(false)

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

/// Per-product custom field definition. Lets each project track its own
/// domain-specific structured data without schema migrations — Furix tracks
/// CVE/CVSS, RozCar tracks KYC status, ManaCalendar tracks Tithi, etc.
/// Values are stored as a JSON map on Task.customFields keyed by definition.key.
enum CustomFieldType {
  TEXT
  NUMBER
  SELECT
  DATE
  URL
  BADGE
}

model CustomFieldDefinition {
  id        String          @id @default(uuid())
  projectId String
  /// Human-readable label shown on inputs and as the column header.
  name      String
  /// Stable machine key used in the Task.customFields JSON map. Must be
  /// unique within a project, lowercase + underscores by convention.
  key       String
  fieldType CustomFieldType
  /// Type-specific config: SELECT options, NUMBER min/max, BADGE color,
  /// TEXT multiline flag, etc. Schema is type-checked at the service layer.
  config    Json            @default("{}")
  required  Boolean         @default(false)
  /// Display order on the task detail panel. Lower = higher.
  order     Int             @default(0)
  /// Optional help text shown under the input.
  hint      String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, key])
  @@index([projectId, order])
  @@map("custom_field_definitions")
}

// Per-user notification mute preferences.
//
// Design:
//   - One row per (userId, type) — sparse storage. The DEFAULT is
//     "not muted"; absence of a row means the user wants the
//     notification. Only opt-OUT entries persist.
//   - `type` is a free-form string matching the values used in
//     notification.service.ts (e.g. 'task_nudge'). NOT a Prisma enum
//     because we add new notification types in nearly every feature
//     PR — a schema migration per new type would be silly. The
//     authoritative list lives in src/constants/notificationTypes.ts
//     and is validated at the validator boundary.
//   - Cascade on user delete: when an account is removed, drop their
//     preferences with them. Don't leak settings to a future user
//     who happens to take the same id (UUIDs make collision
//     impossible in practice, but the cascade is the right safety).
model NotificationPreference {
  id        String   @id @default(uuid())
  userId    String
  type      String
  muted     Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
  @@map("notification_preferences")
}

// ─── AGENT RUNTIME (M2) ───
// An AgentRun is one execution of an agent against a task. RunStep is an
// ordered action within it (plan/edit/test/…); RunEvent is the structured
// trace stream consumed by observability. Runtime-neutral by design — no
// vendor-specific shapes leak into these models.

enum RunStatus {
  QUEUED // created, not yet started
  RUNNING // actively working
  PAUSED // suspended by a human at a turn boundary; resumable (transcript alive in memory)
  AWAITING_REVIEW // opened a PR / done-gate; waiting on a human
  AWAITING_INPUT // blocked on a clarification a human must answer
  BLOCKED // blocked on an external dependency
  SUCCEEDED // completed and accepted
  FAILED // gave up / errored
  CANCELLED // stopped by a human
}

enum RunStepType {
  PLAN
  TOOL_CALL
  EDIT
  COMMAND
  TEST
  REVIEW_REQUEST
}

enum RunStepStatus {
  RUNNING
  SUCCEEDED
  FAILED
}

model AgentRun {
  id        String    @id @default(uuid())
  taskId    String
  agentId   String // the agent User executing this run
  status    RunStatus @default(QUEUED)
  // The runtime adapter that executed this run — so a cancel can reach the right
  // one to abort its in-flight (background) work.
  adapterId String    @default("reference")
  model     String? // model that produced the work (free-form, e.g. claude-opus-4-8)
  summary   String?   @db.Text // agent's run summary: what / why / risks
  error     String?   @db.Text // failure cause when status = FAILED
  // Token usage accumulated across the run's model turns (the loop records it on
  // finish). Cost is derived from these by consumers via a current pricing table,
  // so a stale rate is never baked into storage.
  inputTokens  Int @default(0)
  outputTokens Int @default(0)
  totalTokens  Int @default(0)
  startedAt DateTime? // first transition into RUNNING
  endedAt   DateTime? // transition into a terminal state
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  task   Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agent  User       @relation("AgentRunAgent", fields: [agentId], references: [id])
  steps  RunStep[]
  events RunEvent[]

  @@index([taskId])
  @@index([agentId])
  @@index([status])
  @@map("agent_runs")
}

// Cross-run agent memory — durable learnings (conventions, gotchas, prior
// progress) recalled into a run's context so the agent doesn't relearn the same
// project every time. Scoped by project; advisory (no FK), so a deleted project
// just leaves orphan rows the recall query never reaches.
model AgentMemory {
  id          String   @id @default(uuid())
  projectId   String
  kind        String // e.g. run-summary, convention, gotcha
  content     String   @db.Text
  sourceRunId String? // the run that produced it, when applicable
  // Semantic embedding of `content` (a Float[] stored as JSON) for similarity
  // recall. Null when no embedding model is configured — recall falls back to
  // recency. JSON (not pgvector) keeps it dependency-free; cosine runs in app code.
  embedding   Json?
  createdAt   DateTime @default(now())

  @@index([projectId, createdAt])
  @@map("agent_memories")
}

model RunStep {
  id        String        @id @default(uuid())
  runId     String
  seq       Int // 1-based ordinal within the run
  type      RunStepType
  status    RunStepStatus @default(RUNNING)
  title     String
  detail    String?       @db.Text
  startedAt DateTime      @default(now())
  endedAt   DateTime?

  run AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, seq])
  @@index([runId])
  @@map("run_steps")
}

model RunEvent {
  id      String   @id @default(uuid())
  runId   String
  seq     Int // 1-based ordinal within the run
  type    String // dot-namespaced, e.g. "run.transitioned"
  payload Json     @default("{}")
  at      DateTime @default(now())

  run AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, seq])
  @@index([runId])
  @@map("run_events")
}
