{
  "name": "@exargen/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "npx prisma generate",
    "dev": "tsx watch src/index.ts",
    "build": "npx prisma generate && tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:real-db": "vitest run --config vitest.real-db.config.ts",
    "test:real-db:ci": "docker compose -f ../docker-compose.test.yml up -d --wait && DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5433/exargen_cc_test npm run test:real-db && docker compose -f ../docker-compose.test.yml down -v",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:seed": "tsx src/seed/index.ts",
    "db:studio": "npx prisma studio"
  },
  "prisma": {
    "seed": "tsx src/seed/index.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@exargen/shared": "*",
    "@prisma/client": "^5.18.0",
    "@types/multer": "^2.1.0",
    "@types/pdfkit": "^0.17.6",
    "axios": "^1.7.2",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pdfkit": "^0.18.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^2.1.9",
    "pino-pretty": "^11.3.0",
    "prisma": "^5.18.0",
    "supertest": "^7.2.2",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9",
    "vitest-mock-extended": "^2.0.2"
  }
}
